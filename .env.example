# Required: Telegram Bot Configuration
TELEGRAM_BOT_NAME='Your Bot Name'
TELEGRAM_BOT_TOKEN='your_token_from_botfather'

# Required for Git integration: Connects to repository for default deck generation
DEFAULT_DECK_REPO_URL='your_repository_url_here'
GIT_TOKEN='your_github_token'
GIT_WEBHOOK_SECRET='your_webhook_secret'
GIT_SSH_PASSPHRASE='your_ssh_passphrase'
# Enable/disable Git sync for default deck (both initial and periodic sync)
GIT_SYNC_ENABLED=true
# GitHub Token Requirements and Troubleshooting
# ===========================================
#
# GIT_TOKEN must be a valid GitHub Personal Access Token (PAT) with appropriate scopes.
#
# Token Types:
#   - Classic PAT (starts with 'ghp_'): Expires after 90 days by default
#   - Fine-grained PAT (starts with 'github_pat_'): Custom expiration, repository-specific
#
# Required Scopes:
#   - 'repo' scope: Required for full repository access (including private repositories)
#   - For private repositories: Ensure token has 'repo' scope enabled
#   - For public repositories: 'public_repo' scope may be sufficient
#
# Common Issues:
#   1. Token expired: Classic PATs expire after 90 days by default
#   2. Insufficient scopes: Token lacks 'repo' scope for private repositories
#   3. SAML SSO: For enterprise organizations, token must be authorized for SAML SSO
#   4. Token revoked: Token may have been manually revoked
#
# Troubleshooting:
#   - Check application logs for 'TransportException' or 'not authorized' errors
#   - Validate token via GitHub API: curl -H 'Authorization: token YOUR_TOKEN' https://api.github.com/user
#   - Verify token scopes: curl -H 'Authorization: token YOUR_TOKEN' https://api.github.com/rate_limit
#   - For SAML SSO: Authorize token at https://github.com/settings/tokens
#   - Create new token: https://github.com/settings/tokens/new
#
# Token Creation Steps:
#   1. Go to https://github.com/settings/tokens/new
#   2. Select 'repo' scope (or 'public_repo' for public repositories only)
#   3. For enterprise: Enable 'Enable SSO' and authorize for your organization
#   4. Copy the generated token immediately (won't be shown again)
#
# Note: The bot includes startup validation that checks token validity and logs issues.

# Database Configuration (optional - defaults shown)
TELEGRAM_BOT_DB_USER=postgres
TELEGRAM_BOT_DB_PASSWORD=postgres
TELEGRAM_BOT_DB_HOST=localhost

# Encryption: Used for sensitive data encryption in SecurityConfig
ENCRYPTION_PASSWORD='encryption_password'
ENCRYPTION_SALT='encryption_salt'

# Data Service Configuration
DATA_SERVICE_PORT=50051
# Note: DATA_SERVICE_DB_* variables use TELEGRAM_BOT_DB_* values by default
# DATA_SERVICE_DB_HOST=spaced-repetition-bot-db (set in docker-compose)
# DATA_SERVICE_DB_PORT=5432 (set in docker-compose)
# DATA_SERVICE_DB_NAME=spaced-repetition-bot-db (set in docker-compose)
# DATA_SERVICE_DB_USER=${TELEGRAM_BOT_DB_USER:-postgres} (inherited)
# DATA_SERVICE_DB_PASSWORD=${TELEGRAM_BOT_DB_PASSWORD:-postgres} (inherited)
DATA_SERVICE_DB_MAX_POOL_SIZE=15

# Kafka Configuration (optional)
KAFKA_BOOTSTRAP_SERVERS=localhost