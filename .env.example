# Required: Telegram Bot Configuration
TELEGRAM_BOT_NAME='Your Bot Name'
TELEGRAM_BOT_TOKEN='your_token_from_botfather'

# Required for Git integration: Connects to repository for default deck generation
DEFAULT_DECK_REPO_URL='your_repository_url_here'
GIT_TOKEN='your_github_token'
GIT_WEBHOOK_SECRET='your_webhook_secret'
GIT_SSH_PASSPHRASE='your_ssh_passphrase'
# Enable/disable Git sync for default deck (both initial and periodic sync)
GIT_SYNC_ENABLED=true
# GitHub Token Requirements and Troubleshooting
# ===========================================
#
# GIT_TOKEN must be a valid GitHub Personal Access Token (PAT) with appropriate scopes.
#
# Token Types:
#   - Classic PAT (starts with 'ghp_'): Expires after 90 days by default
#   - Fine-grained PAT (starts with 'github_pat_'): Custom expiration, repository-specific
#
# Required Scopes:
#   - 'repo' scope: Required for full repository access (including private repositories)
#   - For private repositories: Ensure token has 'repo' scope enabled
#   - For public repositories: 'public_repo' scope may be sufficient
#

# Database Configuration (optional - defaults shown)
POSTGRES_DB_HOST=localhost
POSTGRES_DB_PORT=5432
POSTGRES_DB_USER=postgres
POSTGRES_DB_PASSWORD=postgres

# Encryption: Used for sensitive data encryption in SecurityConfig
ENCRYPTION_PASSWORD='encryption_password'
ENCRYPTION_SALT='encryption_salt'